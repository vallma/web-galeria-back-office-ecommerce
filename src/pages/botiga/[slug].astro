---
import Layout from '../../layouts/Layout.astro';
import { getObres, getObraBySlug } from '../../lib/sanity';

export async function getStaticPaths() {
  const obres = await getObres();
  return obres.map(o => ({ params: { slug: o.slug } }));
}

const { slug } = Astro.params;
const obra = await getObraBySlug(slug);
if (!obra) return Astro.redirect('/botiga');

// Base de las funciones de pago (deploy del webhook en Vercel).
// Si la web y las funciones comparten dominio, puede quedar vacío.
const paymentsBase = import.meta.env.PUBLIC_PAYMENTS_BASE_URL ?? '';
---

<Layout title={obra.titol} description={`${obra.titol} — ${obra.artista?.nom ?? ''} — Espai Barri Vell`} image={obra.imatges?.[0]}>
  <section class="section">
    <div class="container obra-layout">
      <!-- Galeria d'imatges -->
      <div class="obra-gallery">
        {obra.imatges?.map((url: string, i: number) => (
          <img
            src={url}
            alt={`${obra.titol} — imatge ${i + 1}`}
            class:list={['gallery-img', { main: i === 0 }]}
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        ))}
      </div>

      <!-- Info i compra -->
      <div class="obra-info">
        <p class="breadcrumb"><a href="/botiga">Botiga</a></p>
        {obra.artista && (
          <p class="obra-artist">
            <a href={`/artistes/${obra.artista.slug}`}>{obra.artista.nom}</a>
          </p>
        )}
        <h1>{obra.titol}</h1>

        <div class="obra-meta">
          {obra.any && <p><span>Any</span> {obra.any}</p>}
          {obra.tecnica && <p><span>Tècnica</span> {obra.tecnica}</p>}
          {obra.dimensions && <p><span>Dimensions</span> {obra.dimensions}</p>}
        </div>

        <p class="obra-price">{obra.preu?.toLocaleString('ca-ES')} €</p>

        {obra.sold
          ? <p class="sold-msg">Aquesta obra ja ha estat venuda</p>
          : (
            <>
              <p class="payment-error" id="payment-error" hidden>El pagament no s'ha completat. Torna-ho a intentar o contacta amb nosaltres.</p>
              <form method="POST" action={`${paymentsBase}/api/redsys-checkout`}>
                <input type="hidden" name="obraId" value={obra._id} />
                <input type="hidden" name="obraSlug" value={slug} />
                <button type="submit" class="btn btn-primary buy-btn">Adquirir obra</button>
              </form>
              <p class="payment-note">Pagament segur amb targeta a través del TPV de BBVA (Redsys)</p>
            </>
          )
        }

        <p class="obra-note">Obra original única. Transport inclòs a Espanya. Contacta'ns per a enviaments internacionals.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Muestra el aviso si Redsys devuelve al usuario tras un pago fallido (?pagament=ko)
  if (new URLSearchParams(location.search).get('pagament') === 'ko') {
    document.getElementById('payment-error')?.removeAttribute('hidden');
  }
</script>

<style>
  .obra-layout { display: grid; grid-template-columns: 1fr 420px; gap: var(--spacing-lg); align-items: start; }
  .obra-gallery { display: flex; flex-direction: column; gap: 0.5rem; }
  .gallery-img { width: 100%; }
  .breadcrumb { font-size: 0.8rem; color: var(--color-gray-light); margin-bottom: 0.75rem; }
  .breadcrumb a { color: var(--color-gray-dark); }
  .obra-artist { font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-gray-light); margin-bottom: 0.5rem; }
  .obra-artist a { color: var(--color-gray-dark); }
  h1 { margin-bottom: var(--spacing-sm); }
  .obra-meta { margin-bottom: var(--spacing-md); border-top: 1px solid var(--color-border); padding-top: var(--spacing-sm); }
  .obra-meta p { display: flex; gap: 0.5rem; font-size: 0.875rem; padding: 0.5rem 0; border-bottom: 1px solid var(--color-border); }
  .obra-meta span { color: var(--color-gray-light); min-width: 100px; }
  .obra-price { font-size: 1.75rem; font-weight: 600; margin-bottom: var(--spacing-sm); }
  .buy-btn { width: 100%; text-align: center; padding: 1rem; font-size: 0.9rem; }
  .sold-msg { padding: 1rem; background: var(--color-cream); text-align: center; color: var(--color-gray-dark); font-size: 0.875rem; }
  .obra-note { margin-top: 1rem; font-size: 0.8rem; color: var(--color-gray-light); line-height: 1.5; }
  .payment-note { margin-top: 0.5rem; font-size: 0.75rem; color: var(--color-gray-light); text-align: center; }
  .payment-error { padding: 0.75rem 1rem; margin-bottom: 0.75rem; background: #fdecea; color: #b3261e; font-size: 0.85rem; }
  @media (max-width: 768px) { .obra-layout { grid-template-columns: 1fr; } }
</style>
