---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getExposicioHero, getPosts } from '../lib/sanity';

const expo = await getExposicioHero();
const posts = await getPosts();
const postsRecents = posts.slice(0, 8);

// "09/04 - 30/05, 2026" a partir de dataInici/dataFi
function ddmm(iso?: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  return `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}`;
}
const anyExpo = expo?.dataFi ? new Date(expo.dataFi).getFullYear() : (expo?.dataInici ? new Date(expo.dataInici).getFullYear() : '');
const dates = expo ? [ddmm(expo.dataInici), ddmm(expo.dataFi)].filter(Boolean).join(' - ') + (anyExpo ? `, ${anyExpo}` : '') : '';
const nomArtista = expo?.artistes?.map((a: { nom: string }) => a.nom).join(' · ');
---

<Layout title="Inici" description="Espai Barri Vell — Espai d'art al cor de Girona. Exposicions, artistes i obra original.">
  <!-- Hero: exposició actual (wireframe) -->
  {expo ? (
    <section class="hero-expo">
      <a class="hero-left" href={`/exposicions/${expo.slug}`}>
        <div class="hero-left-inner">
          <h1 class="hero-name">{nomArtista || expo.titol}</h1>
          {nomArtista && <p class="hero-expo-title">{expo.titol}</p>}
          {dates && <p class="hero-dates">{dates}</p>}
        </div>
      </a>
      <a class="hero-right" href={`/exposicions/${expo.slug}`} aria-label={expo.titol}>
        {expo.portada
          ? <img src={expo.portada} alt={expo.titol} loading="eager" />
          : <div class="hero-noimage"></div>
        }
      </a>
    </section>
  ) : (
    <section class="hero-fallback">
      <div class="container">
        <h1>Espai d'art al cor de Girona</h1>
        <div class="hero-actions">
          <a href="/exposicions" class="btn btn-primary">Exposicions</a>
          <a href="/botiga" class="btn">Botiga</a>
        </div>
      </div>
    </section>
  )}

  <!-- Actualitat (wireframe: carrusel de notícies) -->
  <section class="section">
    <div class="container">
      <h2 class="section-title reveal">Actualitat</h2>
      <div class="news-scroller reveal" id="news-scroller">
        {postsRecents.map(post => (
          <div class="news-item">
            <BlogCard {...post} />
          </div>
        ))}
      </div>
      <div class="news-controls reveal">
        <a href="/blog" class="news-more">Veure més</a>
        <button class="news-arrow" id="news-prev" aria-label="Anterior">&#8592;</button>
        <button class="news-arrow" id="news-next" aria-label="Següent">&#8594;</button>
      </div>
    </div>
  </section>
</Layout>

<script>
  const scroller = document.getElementById('news-scroller');
  const step = () => (scroller?.querySelector('.news-item')?.clientWidth ?? 300) + 24;
  document.getElementById('news-prev')?.addEventListener('click', () => scroller?.scrollBy({ left: -step(), behavior: 'smooth' }));
  document.getElementById('news-next')?.addEventListener('click', () => scroller?.scrollBy({ left: step(), behavior: 'smooth' }));
</script>

<style>
  /* ─── Hero exposició: meitat blava amb tall diagonal + imatge ── */
  .hero-expo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }
  .hero-left {
    background: var(--color-brand-blue);
    clip-path: polygon(0 9%, 100% 0, 100% 100%, 0 100%);
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .hero-left:hover { text-decoration: none; }
  .hero-left-inner { padding: var(--spacing-lg) var(--spacing-md) var(--spacing-lg) max(var(--spacing-md), calc((100vw - var(--container-max)) / 2 + var(--spacing-md))); }
  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-ink);
    margin-bottom: var(--spacing-sm);
    line-height: 1.05;
  }
  .hero-expo-title { font-size: clamp(1.25rem, 2.5vw, 1.6rem); color: var(--color-ink); margin-bottom: 0.5rem; }
  .hero-dates { font-size: 1rem; color: rgba(22, 22, 22, 0.72); }
  .hero-right { display: block; }
  .hero-right img, .hero-noimage {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-noimage { background: var(--color-cream); }

  @media (max-width: 768px) {
    .hero-expo { grid-template-columns: 1fr; min-height: unset; }
    .hero-left { clip-path: polygon(0 4%, 100% 0, 100% 100%, 0 100%); }
    .hero-left-inner { padding: var(--spacing-lg) var(--spacing-sm); }
    .hero-right { min-height: 300px; }
  }

  /* ─── Fallback hero ── */
  .hero-fallback { padding: var(--spacing-xl) 0; border-bottom: 1px solid var(--color-border); }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: var(--spacing-md); }

  /* ─── Actualitat: carrusel ── */
  .news-scroller {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(260px, 30%, 360px);
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
  }
  .news-scroller::-webkit-scrollbar { display: none; }
  .news-item { scroll-snap-align: start; }

  .news-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: var(--spacing-sm);
    justify-content: center;
  }
  .news-more {
    background: var(--color-brand-yellow);
    color: var(--color-ink);
    font-weight: 800;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.65rem 1.4rem;
    text-decoration: none;
  }
  .news-more:hover { text-decoration: none; filter: brightness(0.95); }
  .news-arrow {
    background: var(--color-brand-red);
    color: var(--color-paper);
    border: none;
    width: 38px;
    height: 38px;
    font-size: 1rem;
    cursor: pointer;
    transition: filter 0.2s;
  }
  .news-arrow:hover { filter: brightness(0.9); }
</style>
