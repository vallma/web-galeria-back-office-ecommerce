---
interface Props {
  titol: string;
  slug: string;
  preu: number;
  dimensions?: string;
  tecnica?: string;
  imatgePrincipal?: string;
  artista?: { nom: string; slug: string };
  sold?: boolean;
}
const { titol, slug, preu, dimensions, tecnica, imatgePrincipal, artista, sold } = Astro.props;
---
<article class:list={['artwork-card', 'reveal', { sold }]}>
  <a href={`/botiga/${slug}`}>
    <div class="card-image">
      {imatgePrincipal
        ? <img src={imatgePrincipal} alt={titol} loading="lazy" />
        : <div class="no-image"></div>
      }
      {sold && <span class="sold-badge">Venuda</span>}
      <div class="card-overlay" aria-hidden="true">
        <span class="overlay-title">{titol}</span>
      </div>
    </div>
    <div class="card-body">
      {artista && <p class="card-artist">{artista.nom}</p>}
      <h3>{titol}</h3>
      {dimensions && <p class="card-meta">{dimensions}</p>}
      {tecnica && <p class="card-meta">{tecnica}</p>}
      <p class="card-price">{preu.toLocaleString('ca-ES')} €</p>
    </div>
  </a>
</article>

<style>
  .artwork-card { border: 1px solid var(--color-border); transition: border-color 0.2s; }
  .artwork-card:hover:not(.sold) { border-color: var(--color-black); }
  .artwork-card.sold { opacity: 0.6; }
  .artwork-card a { display: block; text-decoration: none; }

  .card-image {
    aspect-ratio: 3/4;
    overflow: hidden;
    position: relative;
    background: #f5f5f5;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    display: block;
  }
  .artwork-card:hover:not(.sold) .card-image img { transform: scale(1.04); }

  /* Overlay */
  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .artwork-card:hover:not(.sold) .card-overlay {
    opacity: 1;
    transform: translateY(0);
  }
  .overlay-title {
    color: var(--color-white);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-image img { transition: none; }
    .card-overlay { transition: none; }
  }

  .no-image { width: 100%; height: 100%; background: #eee; }
  .sold-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--color-black);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 1;
  }
  .card-body { padding: 1.25rem; }
  .card-artist {
    font-size: 0.75rem;
    color: var(--color-gray-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .card-body h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; }
  .card-meta { font-size: 0.8rem; color: var(--color-gray-dark); margin-bottom: 0.2rem; }
  .card-price { font-size: 1rem; font-weight: 600; margin-top: 0.75rem; }
</style>
